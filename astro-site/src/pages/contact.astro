---
import Layout from '../layouts/Layout.astro';
import ContactPage from '../components/ContactPage';
---

<Layout title="Contact — Send a Calling Card" page="contact">
  <ContactPage client:load />
</Layout>

<style>
  :global(.page-contact main) {
    padding: 0;
    margin: 0;
    height: 100vh;
    overflow: hidden;
  }
  :global(.page-contact .nav-header) {
    display: none;
  }
  :global(.page-contact .site-footer) {
    display: none;
  }
  :global(.page-contact .p5-fixed-controls) {
    display: none;
  }
  :global(.page-contact .particles) {
    display: none;
  }
  :global(.page-contact .corner-decor) {
    display: none;
  }
</style>
