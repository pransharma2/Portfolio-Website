---
import Layout from '../layouts/Layout.astro';

const missions = [
  {
    op: 'Operation: Pipeline Vanguard',
    org: 'Suncor Energy',
    role: 'Data Engineering Analyst — Co-op',
    date: 'May 2024 — Present',
    description: 'Built Azure Data Factory pipelines, Power BI monitoring apps, and incident automation across source-to-gold data layers. Migrated 400 SAP tables from SLT to Datasphere, driving 300K+ in annual savings.',
  },
  {
    op: 'Operation: Data Vault',
    org: 'SDK Tek Services',
    role: 'Data & Analytics Developer',
    date: 'Jan 2023 — Apr 2024',
    description: 'Sustained enterprise data warehouses and delivered BI reports and analytics support across client engagements. Built reusable Snowflake migration automation saving ~3 hours and $550 per object.',
  },
  {
    op: 'Operation: Phantom Curriculum',
    org: 'DS&ML Club — UCalgary',
    role: 'Workshop Director',
    date: 'Sep 2022 — Present',
    description: 'Designed and delivered hands-on sessions for 50+ students covering neural networks, data engineering, and cloud analytics. Sustained 90%+ satisfaction ratings with incentive-based engagement programs.',
  },
];

const skills = [
  {
    number: '01',
    title: 'Data Engineering',
    description: 'Building Azure Data Factory pipelines, Snowflake migrations, and automated ingestion for enterprise data platforms.',
  },
  {
    number: '02',
    title: 'BI & Visualization',
    description: 'Power BI apps, Tableau dashboards, and interactive reports that turn raw data into actionable decisions.',
  },
  {
    number: '03',
    title: 'Python & Automation',
    description: 'Streamlit apps, reusable automation scripts, and PySpark workflows that save hundreds of hours.',
  },
];
---

<Layout title="About — Confidant Profile" page="about">
  <div class="page-banner">Confidant Profile</div>

  <div class="confidant-page">

    <!-- ── 1. Profile: who I am ── -->
    <div class="confidant-profile">
      <div class="confidant-portrait">
        <img
          src="/img/1_P1ZpJoADmVLHN2vjq0cmqw_1762760206212.jpg"
          alt="Prantap portrait photo"
          loading="lazy"
        />
        <span class="rank-badge" aria-label="Star rank">&#9733;</span>
      </div>
      <div class="confidant-bio">
        <div class="confidant-bio-header">
          <span class="confidant-name">Prantap Sharma</span>
          <span class="confidant-location">Calgary, AB</span>
        </div>
        <p>
          Data Analytics &amp; Engineering specialist pursuing a dual BComm in Business Analytics
          and BSc in Computer Science at the University of Calgary. Experienced building enterprise
          data pipelines at Suncor Energy, sustaining data warehouses at SDK Tek Services, and
          leading workshops for 50+ students as Workshop Director of the DS&amp;ML Club.
        </p>
        <div class="confidant-tags">
          <span class="p5-tag">Azure</span>
          <span class="p5-tag">Snowflake</span>
          <span class="p5-tag">Power BI</span>
          <span class="p5-tag">Python</span>
          <span class="p5-tag">PySpark</span>
          <span class="p5-tag">U of C</span>
        </div>
      </div>
    </div>

    <hr class="p5-divider" />

    <!-- ── 2. Infiltration Log: experience timeline ── -->
    <div>
      <div class="section-header">Infiltration Log</div>
      <div class="mission-log">
        {missions.map((m) => (
          <div class="mission-entry">
            <span class="mission-date">{m.date}</span>
            <div class="mission-op">{m.op}</div>
            <div class="mission-org">{m.org}</div>
            <div class="mission-role">{m.role}</div>
            <p class="mission-desc">{m.description}</p>
          </div>
        ))}
      </div>
    </div>

    <hr class="p5-divider" />

    <!-- ── 3. Skill Domains ── -->
    <div>
      <div class="section-header">Skill Domains</div>
      <div class="skill-cards">
        {skills.map((skill) => (
          <div class="skill-card">
            <span class="skill-number">{skill.number}</span>
            <h3>{skill.title}</h3>
            <p>{skill.description}</p>
          </div>
        ))}
      </div>
    </div>

  </div>
</Layout>
