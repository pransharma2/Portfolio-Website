---
import Layout from '../layouts/Layout.astro';
import ArcanaCards from '../components/ArcanaCards';

const stats = [
  { label: 'Knowledge', detail: 'Data Science & Analytics', stars: 4, icon: '/img/fixed_traits_from_user/knowledge.png' },
  { label: 'Proficiency', detail: 'Python / SQL / PySpark', stars: 5, icon: '/img/fixed_traits_from_user/Proficiency.png' },
  { label: 'Charm', detail: 'Power BI / Tableau', stars: 4, icon: '/img/fixed_traits_from_user/charm.png' },
  { label: 'Guts', detail: 'ETL & Data Pipelines', stars: 4, icon: '/img/fixed_traits_from_user/Guts.png' },
  { label: 'Kindness', detail: 'Workshops & Mentoring', stars: 3, icon: '/img/fixed_traits_from_user/Kindness.png' },
];

const skills = [
  {
    title: 'Data Engineering',
    description: 'Building Azure Data Factory pipelines, Snowflake migrations, and automated ingestion for enterprise data platforms.',
  },
  {
    title: 'BI & Visualization',
    description: 'Power BI apps, Tableau dashboards, and interactive reports that turn raw data into actionable decisions.',
  },
  {
    title: 'Python & Automation',
    description: 'Streamlit apps, reusable automation scripts, and PySpark workflows that save hundreds of hours.',
  },
];
---

<Layout title="About — Confidant Profile" page="about">
  <!-- Page Banner -->
  <div class="page-banner">Confidant Profile</div>

  <div class="confidant-page">
    <!-- Profile Section -->
    <div class="confidant-profile">
      <div class="confidant-portrait">
        <img
          src="/img/1_P1ZpJoADmVLHN2vjq0cmqw_1762760206212.jpg"
          alt="Prantap portrait photo"
          loading="lazy"
        />
        <span class="rank-badge" aria-label="Star rank">&#9733;</span>
      </div>
      <div class="confidant-bio">
        <p>
          <strong>Prantap Sharma</strong> — Data Analytics & Engineering specialist based in Calgary, AB.
          Pursuing a dual BComm in Business Analytics and BSc in Computer Science at the University of Calgary.
          Experienced in building enterprise data pipelines at Suncor Energy, sustaining data warehouses at SDK Tek Services,
          and leading workshops for 50+ students as Workshop Director of the DS&ML Club.
          Always looking for new shadows to defeat in the Metaverse of analytics.
        </p>
      </div>
    </div>

    <!-- Social Stats Section -->
    <div class="social-stats">
      {stats.map((stat) => (
        <div class="stat-bar">
          <img
            src={stat.icon}
            alt={`${stat.label} icon`}
            loading="lazy"
            class="stat-icon"
          />
          <div class="stat-info">
            <span class="stat-name">{stat.label}</span>
            <span class="stat-value">{stat.detail}</span>
          </div>
          <div class="stat-stars" aria-label={`${stat.stars} out of 5`}>
            {Array.from({ length: 5 }).map((_, i) => (
              <span class:list={['star', { empty: i >= stat.stars }]} />
            ))}
          </div>
        </div>
      ))}
    </div>

    <hr class="p5-divider" />

    <!-- Skill Cards -->
    <div class="skill-cards">
      {skills.map((skill) => (
        <div class="skill-card">
          <h3>{skill.title}</h3>
          <p>{skill.description}</p>
        </div>
      ))}
    </div>

    <hr class="p5-divider" />

    <!-- Confidants Video Showcase -->
    <div class="confidants-video-section">
      <video autoplay muted loop playsinline preload="auto">
        <source src="/img/persona_5_confidants_50mbs.mp4" type="video/mp4" />
      </video>
      <div class="confidants-video-overlay"></div>
    </div>

    <hr class="p5-divider" />

    <!-- Arcana Cards -->
    <ArcanaCards client:visible />
  </div>
</Layout>
