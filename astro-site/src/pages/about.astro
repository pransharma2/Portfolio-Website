---
import Layout from '../layouts/Layout.astro';
import AboutChapters from '../components/AboutChapters.tsx';
---

<Layout title="About — Confidant Profile" page="about">
  <AboutChapters client:load />
</Layout>

<style>
  /* AboutChapters now renders a naturally-scrolling Confidant Profile
     page, so let the document own scrolling instead of locking to 100vh. */
  :global(.page-about main) {
    padding: 0;
    margin: 0;
  }
  /* The new design ships its own sticky nav + footer ticker; hide the
     global chrome so the layout stays edge-to-edge. */
  :global(.page-about .nav-header) {
    display: none;
  }
  :global(.page-about .site-footer) {
    display: none;
  }
  :global(.page-about .p5-fixed-controls) {
    display: none;
  }
  :global(.page-about .particles) {
    display: none;
  }
  :global(.page-about .corner-decor) {
    display: none;
  }
</style>
