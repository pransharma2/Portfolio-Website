---
import Layout from '../layouts/Layout.astro';
import AboutChapters from '../components/AboutChapters.tsx';
---

<Layout title="About — Confidant Profile" page="about">
  <AboutChapters client:load />
</Layout>

<style>
  /* Let the scroll container inside AboutChapters own the viewport */
  :global(.page-about main) {
    padding: 0;
    margin: 0;
    height: 100vh;
    overflow: hidden;
  }
  :global(.page-about .nav-header) {
    display: none;
  }
  :global(.page-about .site-footer) {
    display: none;
  }
  :global(.page-about .p5-fixed-controls) {
    display: none;
  }
  :global(.page-about .particles) {
    display: none;
  }
  :global(.page-about .corner-decor) {
    display: none;
  }
</style>
