---
import Layout from '../layouts/Layout.astro';
import ProjectsPage from '../components/ProjectsPage';
import { projects } from '../data/projects';
---

<Layout title="Projects — Persona Compendium" page="projects">
  <ProjectsPage client:load projects={projects} />
</Layout>

<style>
  :global(.page-projects main) {
    padding: 0;
    margin: 0;
    height: 100vh;
    overflow: hidden;
  }
  :global(.page-projects .nav-header) {
    display: none;
  }
  :global(.page-projects .site-footer) {
    display: none;
  }
  :global(.page-projects .p5-fixed-controls) {
    display: none;
  }
  :global(.page-projects .particles) {
    display: none;
  }
  :global(.page-projects .corner-decor) {
    display: none;
  }
</style>
