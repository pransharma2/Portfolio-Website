---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Home — Phantom Dev Portfolio" page="home">
  <!-- Background video placeholder — will be added later -->

  <!-- Hero Section -->
  <section class="p5-hero">
    <div class="p5-hero-title-card">
      <h1 class="p5-hero-title">Prantap's Portfolio</h1>
      <p class="p5-hero-subtitle">Take Your Heart &mdash; enter the Metaverse of my work.</p>
    </div>
  </section>

  <!-- Battle Menu Navigation -->
  <nav class="p5-battle-menu" aria-label="Quick navigation">
    <a href="/about" class="p5-battle-menu-item">
      <img src="/img/about-me.png" alt="About Me icon" loading="lazy" class="p5-battle-icon" />
      <span class="p5-battle-label">About</span>
    </a>
    <a href="/projects" class="p5-battle-menu-item">
      <img src="/img/projects.png" alt="Projects icon" loading="lazy" class="p5-battle-icon" />
      <span class="p5-battle-label">Projects</span>
    </a>
    <a href="/contact" class="p5-battle-menu-item">
      <img src="/img/contact.png" alt="Contact icon" loading="lazy" class="p5-battle-icon" />
      <span class="p5-battle-label">Contact</span>
    </a>
  </nav>

  <!-- Weather Widget Placeholder -->
  <div class="p5-weather-widget" aria-label="Weather widget placeholder"></div>

  <!-- Joker Silhouette Decoration -->
  <div class="p5-joker-silhouette">
    <img
      src="/img/joker-cutin.png"
      alt="Joker silhouette decorative element"
      loading="lazy"
      class="p5-joker-img"
    />
  </div>
</Layout>
