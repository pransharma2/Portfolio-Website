---
import Layout from '../layouts/Layout.astro';
import JokerCutIn from '../components/JokerCutIn';
import WeatherWidget from '../components/WeatherWidget';
import ProofStrip from '../components/ProofStrip';
import TextReveal from '../components/TextReveal';
import { impactMetrics } from '../data/metrics';
---

<Layout title="Home — Phantom Dev Portfolio" page="home">
  <!-- Hero Section -->
  <section class="hero">
    <!-- Fullscreen looping background video (muted by default; SoundToggle controls audio) -->
    <div class="hero-video-bg">
      <video
        autoplay
        muted
        loop
        playsinline
        preload="auto"
        poster="/img/p5_wall.jpg"
      >
        <source src="/img/home_page_50MBs.mp4" type="video/mp4" />
      </video>
    </div>

    <div class="hero-inner">
      <div class="hero-title-card">
        <!-- Joker mask accent (Part 7) -->
        <img
          src="/img/jokersmask.png"
          alt=""
          class="hero-mask-accent"
          loading="lazy"
          aria-hidden="true"
        />
        <h1>Prantap's Portfolio</h1>
        <p class="hero-sub">Take Your Heart &mdash; enter the Metaverse of my work.</p>
        <div class="hero-socials">
          <a href="https://github.com/pransharma2" target="_blank" rel="noopener noreferrer" aria-label="GitHub" class="hero-social-link">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
          </a>
          <a href="https://www.linkedin.com/in/prantap-sharma-2ab1662bb" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="hero-social-link">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
          <a href="mailto:s.prantap@gmail.com" aria-label="Email" class="hero-social-link">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4-8 5-8-5V6l8 5 8-5v2z"/></svg>
          </a>
        </div>
      </div>

      <!-- P5-style battle menu navigation -->
      <nav class="p5-menu" aria-label="Quick navigation">
        <a href="/about" class="p5-menu-item">
          <img src="/img/about-me.png" alt="" loading="lazy" class="menu-icon" />
          <span class="menu-label">About</span>
        </a>
        <a href="/projects" class="p5-menu-item">
          <img src="/img/projects.png" alt="" loading="lazy" class="menu-icon" />
          <span class="menu-label">Projects</span>
        </a>
        <a href="/contact" class="p5-menu-item">
          <img src="/img/contact.png" alt="" loading="lazy" class="menu-icon" />
          <span class="menu-label">Contact</span>
        </a>
      </nav>
    </div>
  </section>

  <!-- Impact proof strip — hard numbers -->
  <TextReveal client:idle tag="h2" className="proof-strip-heading">
    Impact at a Glance
  </TextReveal>
  <ProofStrip client:idle metrics={impactMetrics} />

  <!-- Joker cut-in intro animation (once per session) -->
  <JokerCutIn client:load />

  <!-- P5 weather/date widget (top-right of home page) -->
  <WeatherWidget client:load />
</Layout>
