---
import Layout from '../layouts/Layout.astro';
import HomeHero from '../components/HomeHero';
---

<Layout title="Home — Phantom Dev Portfolio" page="home">
  <HomeHero client:load />
</Layout>

<style>
  /* Make the home page fill the viewport for the fixed hero */
  :global(.page-home main) {
    padding: 0;
    margin: 0;
    min-height: 100vh;
  }
  :global(.page-home .nav-header) {
    display: none;
  }
  :global(.page-home .site-footer) {
    display: none;
  }
  :global(.page-home .p5-fixed-controls) {
    display: none;
  }
  :global(.page-home .particles) {
    display: none;
  }
  :global(.page-home .corner-decor) {
    display: none;
  }
</style>
