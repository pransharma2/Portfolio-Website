---
import '../styles/global.css';
import SoundToggle from '../components/SoundToggle';
import ThemeToggle from '../components/ThemeToggle';
import PageTransition from '../components/PageTransition';
import TakeYourTimeTransition from '../components/TakeYourTimeTransition';

interface Props {
  title: string;
  page: string;
}

const { title, page } = Astro.props;

const navLinks = [
  { label: 'Home',     href: '/',         key: 'home'     },
  { label: 'About',    href: '/about',    key: 'about'    },
  { label: 'Projects', href: '/projects', key: 'projects' },
  { label: 'Contact',  href: '/contact',  key: 'contact'  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Prantap Sharma — Data Analytics & Engineering portfolio" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/png" href="/img/favicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Arsenal:ital,wght@0,400;0,700;1,400;1,700&family=Bebas+Neue&family=Fjalla+One&display=swap"
      rel="stylesheet"
    />
    <!-- Anti-flash: set theme before paint -->
    <script is:inline>
      (function(){
        var t = 'dark';
        try { t = localStorage.getItem('theme') || t; } catch(e){}
        if (t !== 'dark' && t !== 'light') {
          t = window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
        }
        document.documentElement.setAttribute('data-theme', t);
      })();
    </script>
    <title>{title}</title>
  </head>

  <body class={`page-${page}`}>

    <!-- Page-reveal sweep: starts covering, animates off to reveal new page -->
    <!-- Plays on every hard navigation, creating a cinematic entry feel -->
    <div id="p5-page-reveal" aria-hidden="true"></div>

    <!-- Floating ambient particles -->
    <div class="particles">
      <div class="particle"></div>
      <div class="particle"></div>
      <div class="particle"></div>
      <div class="particle"></div>
      <div class="particle"></div>
      <div class="particle"></div>
      <div class="particle"></div>
      <div class="particle"></div>
    </div>

    <!-- Corner geometric decorations -->
    <div class="corner-decor corner-decor--top-left"></div>
    <div class="corner-decor corner-decor--bottom-right"></div>

    <!-- ── Navigation ── -->
    <header class="nav-header">
      <a href="/" class="nav-logo">
        <span class="logo-phantom">Phantom</span><span class="logo-dev">Dev</span>
      </a>

      <button
        class="nav-hamburger"
        aria-label="Toggle navigation"
        aria-expanded="false"
        aria-controls="nav-mobile"
      >
        <span></span>
        <span></span>
        <span></span>
      </button>

      <div class="nav-links" role="navigation" aria-label="Main navigation">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class:list={['nav-link', { active: page === link.key }]}
          >
            {link.label}
          </a>
        ))}
      </div>
    </header>

    <!-- Mobile nav overlay -->
    <nav id="nav-mobile" class="nav-mobile-overlay" aria-label="Mobile navigation">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class:list={['nav-link', { active: page === link.key }]}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <!-- Main content -->
    <main>
      <slot />
    </main>

    <!-- Footer -->
    <footer class="site-footer">
      <div class="footer-inner">
        <span class="footer-logo">Phantom<span class="footer-dev">Dev</span></span>
        <span class="footer-divider">—</span>
        <span class="footer-copy">&copy; 2025 Prantap Sharma</span>
      </div>
    </footer>

    <!-- Fixed UI: sound toggle + theme toggle -->
    <div class="p5-fixed-controls">
      <ThemeToggle client:load />
      <SoundToggle client:load />
    </div>

    <!-- Full-screen cinematic page transition overlays -->
    <PageTransition client:load />
    <TakeYourTimeTransition client:load />

    <script>
      // ── Hamburger menu toggle ──────────────────────────────────
      const hamburger = document.querySelector('.nav-hamburger') as HTMLButtonElement | null;
      const overlay   = document.querySelector('.nav-mobile-overlay') as HTMLElement | null;

      if (hamburger && overlay) {
        hamburger.addEventListener('click', () => {
          const isOpen = overlay.classList.toggle('open');
          hamburger.classList.toggle('open');
          hamburger.setAttribute('aria-expanded', String(isOpen));
        });
        // Close on any nav link click (mobile)
        overlay.querySelectorAll('.nav-link').forEach(link => {
          link.addEventListener('click', () => {
            overlay.classList.remove('open');
            hamburger.classList.remove('open');
            hamburger.setAttribute('aria-expanded', 'false');
          });
        });
      }

      // ── Scroll-reveal with IntersectionObserver ────────────────
      if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        const io = new IntersectionObserver(
          entries => entries.forEach(e => {
            if (e.isIntersecting) {
              e.target.classList.add('revealed');
              io.unobserve(e.target);
            }
          }),
          { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
        );
        document.querySelectorAll('.scroll-reveal').forEach(el => io.observe(el));
      }
    </script>
  </body>
</html>
