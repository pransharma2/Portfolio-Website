---
import '../styles/global.css';
import SoundToggle from '../components/SoundToggle';
import PageTransition from '../components/PageTransition';

interface Props {
  title: string;
  page: string;
}

const { title, page } = Astro.props;

const navLinks = [
  { label: 'Home', href: '/', key: 'home' },
  { label: 'About', href: '/about', key: 'about' },
  { label: 'Projects', href: '/projects', key: 'projects' },
  { label: 'Contact', href: '/contact', key: 'contact' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Persona 5 themed portfolio website" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/png" href="/img/favicon.png" />
    <link
      rel="preconnect"
      href="https://fonts.googleapis.com"
    />
    <link
      rel="preconnect"
      href="https://fonts.gstatic.com"
      crossorigin
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Arsenal:ital,wght@0,400;0,700;1,400;1,700&family=Bebas+Neue&family=Fjalla+One&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body class={`page-${page}`}>
    <!-- Animated Background Layer -->
    <div class="p5-bg-layer">
      <div class="p5-bg-diamonds"></div>
      <div class="p5-bg-stripes"></div>
      <div class="p5-bg-halftone"></div>
      <div class="p5-bg-crosshatch"></div>
      <div class="p5-bg-vignette"></div>
    </div>

    <!-- Floating Particles -->
    <div class="p5-particles">
      <div class="p5-particle"></div>
      <div class="p5-particle"></div>
      <div class="p5-particle"></div>
      <div class="p5-particle"></div>
      <div class="p5-particle"></div>
      <div class="p5-particle"></div>
      <div class="p5-particle"></div>
      <div class="p5-particle"></div>
    </div>

    <!-- Corner Decorations -->
    <div class="p5-corner-decor p5-corner-top-left"></div>
    <div class="p5-corner-decor p5-corner-bottom-right"></div>

    <!-- Header -->
    <header class="p5-header">
      <nav class="p5-nav">
        <a href="/" class="p5-logo">Phantom Dev</a>

        <button class="p5-hamburger" aria-label="Toggle navigation" aria-expanded="false">
          <span class="p5-hamburger-line"></span>
          <span class="p5-hamburger-line"></span>
          <span class="p5-hamburger-line"></span>
        </button>

        <ul class="p5-nav-links">
          {navLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class:list={['p5-nav-link', { active: page === link.key }]}
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </header>

    <!-- Main Content -->
    <main class="p5-main">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="p5-footer">
      <p>&copy; 2025 Prantap &bull; Persona 5 Portfolio</p>
    </footer>

    <!-- Sound Toggle -->
    <div class="p5-sound-toggle-wrapper">
      <SoundToggle client:load />
    </div>

    <!-- Page Transition Overlay -->
    <PageTransition client:load />

    <script>
      // Hamburger menu toggle
      const hamburger = document.querySelector('.p5-hamburger');
      const navLinks = document.querySelector('.p5-nav-links');

      if (hamburger && navLinks) {
        hamburger.addEventListener('click', () => {
          const isOpen = navLinks.classList.toggle('open');
          hamburger.classList.toggle('open');
          hamburger.setAttribute('aria-expanded', String(isOpen));
        });
      }
    </script>
  </body>
</html>
